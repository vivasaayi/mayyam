# syntax=docker/dockerfile:1.7

ARG SCCACHE_VERSION=0.14.0
ARG BACKEND_BASE_IMAGE=ghcr.io/sumitharajan/mayyam/mayyam-backend-base:latest

FROM ${BACKEND_BASE_IMAGE}


ARG TARGETARCH
ARG SCCACHE_VERSION

ENV RUSTC_WRAPPER=/usr/local/cargo/bin/sccache \
    SCCACHE_DIR=/var/cache/sccache \
    SCCACHE_CACHE_SIZE=10G


WORKDIR /usr/src/app

# Copy Cargo files first to cache dependencies
COPY Cargo.toml Cargo.lock ./
COPY .cargo ./.cargo

# Create dummy src and build test dependencies
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/var/cache/sccache,sharing=locked \
    mkdir -p src/bin && \
    echo "pub fn dummy() {}" > src/lib.rs && \
    echo "fn main() {}" > src/main.rs && \
    echo "fn main() {}" > src/bin/hash_password.rs && \
    echo "fn main() {}" > src/bin/temp_hash.rs && \
    mkdir -p tests && \
    echo "#[test] fn dummy_test() {}" > tests/integration.rs && \
    sccache --zero-stats && \
    (cargo test --no-run --workspace || true) && \
    (sccache --show-stats || true) && \
    rm -rf src tests target/debug/deps/mayyam* target/debug/mayyam* target/debug/.fingerprint/mayyam*

# Now copy the workspace crates
COPY . ./backend

WORKDIR /usr/src/app/backend

# Build tests (dependencies are already cached)
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/var/cache/sccache,sharing=locked \
    sccache --zero-stats && \
    (cargo test --no-run --workspace || true) && \
    (sccache --show-stats || true)

# Install cargo-nextest for JUnit-style reports
RUN cargo install cargo-nextest || true
RUN cargo install cargo2junit || true

CMD ["bash", "-lc", "mkdir -p test-results && (cargo nextest run --profile ci --junit output=test-results/junit.xml || (cargo test --test integration -- --nocapture | cargo2junit > test-results/junit.xml))"]
